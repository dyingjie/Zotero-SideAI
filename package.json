{
  "name": "zotero-sideai",
  "type": "module",
  "version": "0.1.0",
  "description": "A Zotero 8 sidebar AI plugin skeleton.",
  "config": {
    "addonName": "Zotero SideAI",
    "addonID": "sideai@dyingjie.github.io",
    "addonRef": "sideai",
    "addonInstance": "SideAI",
    "prefsPrefix": "extensions.zotero.sideai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyingjie/Zotero-SideAI.git"
  },
  "author": "dyingjie",
  "bugs": {
    "url": "https://github.com/dyingjie/Zotero-SideAI/issues"
  },
  "homepage": "https://github.com/dyingjie/Zotero-SideAI#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
